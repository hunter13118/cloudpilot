# Frontend build-time config (safe to expose — these ship in the client bundle).
# Copy to .env.local for local dev. In Cloudflare, set these as Pages env vars.

# Clerk publishable key. LEAVE BLANK to run ungated in demo mode (the app still
# builds and works). Set it to turn /project into a real login gate.
VITE_CLERK_PUBLISHABLE_KEY=

# ── NOT set here (these are SERVER-side secrets, set in the Cloudflare dashboard
#    under Pages → Settings → Environment variables, never committed) ──
#   GEMINI_API_KEY   — shared key used by the edge function for operators
#   CLERK_JWKS_URL   — https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
#   CLERK_ISSUER     — (optional) https://<your-app>.clerk.accounts.dev
